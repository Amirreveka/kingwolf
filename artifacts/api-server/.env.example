# Copy this to .env and fill in your values

# ── Ports ─────────────────────────────────────────────────────────────────────
PORT=3001

# ── MariaDB ───────────────────────────────────────────────────────────────────
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DATABASE=kingwolf
MARIADB_USERNAME=kingwolf
MARIADB_PASSWORD=your_mariadb_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Option 1 — URL form (takes precedence if set):
# REDIS_URL=redis://:password@host:6379
# Option 2 — individual fields:
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string

# ── Founder account (auto-seeded on first boot) ────────────────────────────────
FOUNDER_ROOT_USERNAME=Amirreveka
FOUNDER_ROOT_PASSWORD=Apps76417@amir

# ── Optional: Stealth owner username ─────────────────────────────────────────
# STEALTH_OWNER_USERNAME=

# ── Optional: S3 / Object Storage ────────────────────────────────────────────
# S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
# S3_BUCKET_NAME=kingwolf-media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Optional: Google OAuth ────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback
